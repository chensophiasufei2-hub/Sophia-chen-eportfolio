  content: "";
  position: absolute;
  top: -20%;
  left: -120%;
  width: 70%;
  height: 140%;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.28) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-18deg);
  transition: left 0.55s ease;
}

