  max-width: 1120px;
  margin: 0 auto 2.6rem auto;
  background: linear-gradient(180deg, #eef2ff 0%, #e6ebfb 100%);
  border-radius: 28px;
  padding: 1.6rem;
  box-shadow: 0 10px 22px rgba(120, 130, 170, 0.10);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.connect-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.connect-field {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.connect-field label {
  font-weight: 700;
  color: #5f6477;
}

.connect-field input {
  height: 52px;
  border-radius: 16px;
  border: 1px solid rgba(140, 150, 210, 0.25);
  padding: 0 1rem;
  font-size: 0.98rem;
  outline: none;
  background: #ffffff;
  color: #5a6070;
}

.connect-btn {
  align-self: flex-start;
  height: 52px;
  padding: 0 1.3rem;
  border: none;
  border-radius: 999px;
  background: linear-gradient(90deg, #7d86df 0%, #9fa7ef 100%);
  color: #ffffff;
  font-weight: 700;
  font-size: 0.98rem;
  cursor: pointer;
}

.connect-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(22, 28, 45, 0.45);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(3px);
}

.connect-modal-box {
  background: #ffffff;
  border-radius: 24px;
  padding: 1.6rem 1.8rem;
  min-width: 320px;
  max-width: 90vw;
  text-align: center;
  box-shadow: 0 18px 34px rgba(60, 70, 110, 0.18);
}

.connect-modal-box p {
  margin: 0 0 1rem 0;
  color: #5a6070;
  font-size: 1rem;
  font-weight: 600;
}

.connect-modal-box button {
  border: none;
  border-radius: 999px;
  padding: 0.7rem 1.1rem;
  background: #7d86df;
  color: #ffffff;
  font-weight: 700;
  cursor: pointer;
}

@media (max-width: 800px) {
  .connect-grid {
    grid-template-columns: 1fr;
  }
}


