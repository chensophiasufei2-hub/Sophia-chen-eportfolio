body {
  background:
    linear-gradient(rgba(248, 242, 250, 0.32), rgba(238, 240, 248, 0.38)),
    url("images/homepage.jpg") center center / cover fixed no-repeat !important;
}

.navbar {
  background-color: #10233f !important;
}

.navbar-brand,
.navbar-nav .nav-link {
  color: white !important;
  font-weight: 600;
}

.navbar-nav .nav-link:hover {
  color: #dbeafe !important;
}

main.content {
  max-width: 1380px;
  width: 95%;
  margin: 0 auto;
  padding-top: 1rem;
  padding-bottom: 2rem;
}

#title-block-header {
  display: none;
}

.homepage-shell {
  background:
    linear-gradient(rgba(130, 165, 210, 0.18), rgba(120, 160, 205, 0.16)),
    url("images/home-bg.jpg");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  border-radius: 22px;
  padding: 1.2rem 1.4rem;
  box-shadow: 0 12px 24px rgba(70, 110, 160, 0.10);
  width: 100%;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.7fr 0.6fr;
  gap: 1.2rem;
  align-items: center;
  margin-bottom: 0.9rem;
  background: rgba(255,255,255,0.84);
  border-radius: 20px;
  padding: 1.1rem 1.25rem;
}

.hero-text h1 {
  font-size: 2.3rem;
  color: #102a43;
  margin-bottom: 0.35rem;
  line-height: 1.05;
}

.hero-subtitle {
  font-size: 0.95rem;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 0.55rem;
}

.linkedin-callout {
  color: #173a63;
  font-size: 0.92rem;
  margin-bottom: 0.75rem;
  max-width: 95%;
  background: rgba(255,255,255,0.55);
  border-left: 4px solid #3b82f6;
  padding: 0.7rem 0.85rem;
  border-radius: 12px;
}

.hero-image {
  text-align: center;
}

.hero-image img {
  width: 100%;
  max-width: 180px;
  max-height: 220px;
  object-fit: cover;
  border-radius: 20px;
  display: inline-block;
  border: 4px solid rgba(255,255,255,0.45);
  box-shadow: 0 10px 20px rgba(90, 120, 160, 0.14);
}

.btn,
a.btn {
  display: inline-block;
  margin-right: 0.5rem;
  margin-top: 0.25rem;
  padding: 0.62rem 0.92rem;
  border-radius: 999px;
  font-weight: 600;
  text-decoration: none !important;
  font-size: 0.95rem;
}

.btn-primary {
  background: #3b82f6;
  border: none;
  color: white !important;
}

.btn-outline-primary {
  border: 2px solid #60a5fa;
  color: #1d4ed8 !important;
  background: rgba(255,255,255,0.75);
}

.btn-outline-dark {
  border: 2px solid #1e3a5f;
  color: #1e3a5f !important;
  background: rgba(255,255,255,0.8);
}

.section-title {
  margin-top: 0.6rem;
  margin-bottom: 0.45rem;
}

.section-title h2 {
  color: #12345a;
  margin: 0;
  border-bottom: 2px solid rgba(59, 130, 246, 0.18);
  padding-bottom: 0.22rem;
  font-size: 1.32rem;
}

.highlight-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
  margin: 0.65rem 0 0.85rem 0;
  width: 100%;
}

.highlight-card {
  border-radius: 16px;
  padding: 1rem 1.05rem;
  min-height: 120px;
  box-shadow: 0 6px 14px rgba(80, 120, 170, 0.08);
  border: 1px solid rgba(255,255,255,0.55);
  background: rgba(255,255,255,0.80);
}

.highlight-card h3 {
  margin-top: 0.05rem;
  margin-bottom: 0.18rem;
  color: #12345a;
  font-size: 1rem;
}

.highlight-card p {
  margin: 0;
  color: #2f4f73;
  font-size: 0.9rem;
  line-height: 1.45;
}

.card-blue-1 {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.card-blue-2 {
  background: linear-gradient(135deg, #d6ecff, #c7e3ff);
}

.card-blue-3 {
  background: linear-gradient(135deg, #e0f2fe, #bae6fd);
}

.card-blue-4 {
  background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
}

.contact-strip {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  color: #12345a;
  padding: 0.8rem 0.9rem;
  border-radius: 16px;
  box-shadow: 0 6px 14px rgba(80, 120, 170, 0.08);
  margin-top: 0.7rem;
}

.contact-strip h3 {
  color: #12345a;
  margin-top: 0;
  margin-bottom: 0.35rem;
  font-size: 0.98rem;
}

.contact-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.65rem;
}

.contact-pill {
  background: rgba(255,255,255,0.65);
  border-radius: 12px;
  padding: 0.62rem 0.75rem;
  color: #23486d;
  font-weight: 500;
  font-size: 0.88rem;
}

img {
  max-width: 100%;
  height: auto;
  border-radius: 18px;
}

@media (max-width: 800px) {
  .hero-grid,
  .highlight-grid,
  .contact-row {
    grid-template-columns: 1fr;
  }

  .linkedin-callout {
    max-width: 100%;
  }

  .hero-image img {
    max-width: 160px;
    max-height: 190px;
  }
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.9rem;
}

.skill-card {
  background: rgba(255,255,255,0.88);
  border-radius: 18px;
  padding: 1rem;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
}

.skill-card h3 {
  font-size: 1rem;
  color: #12345a;
  margin-bottom: 0.4rem;
}

.skill-card p {
  font-size: 0.9rem;
  color: #36597d;
  margin: 0;
  line-height: 1.5;
}

@media (max-width: 900px) {
  .skills-grid {
    grid-template-columns: 1fr;
  }
}

/* About page stable style */
body.page-about main.content img,
main.content img[alt="Sophia Sufei Chen lifestyle photo"] {
  max-width: 320px;
  width: 100%;
  display: block;
  margin: 0 auto 1.2rem auto;
  border-radius: 22px;
  box-shadow: 0 10px 22px rgba(80, 120, 170, 0.12);
}

main.content h1 {
  color: #102a43;
}

main.content h2 {
  color: #12345a;
  margin-top: 1.4rem;
  border-bottom: 2px solid rgba(59, 130, 246, 0.18);
  padding-bottom: 0.2rem;
}

main.content h3 {
  color: #1d4ed8;
  margin-top: 1rem;
  margin-bottom: 0.35rem;
}

main.content p,
main.content li {
  color: #36597d;
  font-size: 0.98rem;
  line-height: 1.7;
}

main.content ul {
  padding-left: 1.2rem;
}

/* Smaller image for About page */
main.content img {
  max-width: 220px;
  width: 100%;
  display: block;
  margin: 0 auto 1rem auto;
  border-radius: 20px;
  box-shadow: 0 8px 18px rgba(80, 120, 170, 0.10);
}

/* About redesign */
.about-shell {
  background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(240,247,255,0.92));
  border-radius: 24px;
  padding: 1.5rem;
  box-shadow: 0 12px 24px rgba(80, 120, 170, 0.08);
}

.about-hero {
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  gap: 1.2rem;
  align-items: start;
  background: rgba(255,255,255,0.82);
  border-radius: 22px;
  padding: 1.3rem;
}

.about-hero-text h1 {
  font-size: 2.4rem;
  margin-bottom: 0.6rem;
  color: #102a43;
}

.about-lead {
  font-size: 1.05rem;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 0.8rem;
}

.about-hero-text p {
  color: #36597d;
  line-height: 1.7;
}

.about-hero-photo img {
  width: 100%;
  max-width: 260px;
  display: block;
  margin-left: auto;
  border-radius: 20px;
  box-shadow: 0 10px 22px rgba(80, 120, 170, 0.12);
}

.about-section {
  margin-top: 1.5rem;
}

.about-section h2 {
  font-size: 1.55rem;
  color: #12345a;
  margin-bottom: 0.8rem;
  border-bottom: 2px solid rgba(59, 130, 246, 0.18);
  padding-bottom: 0.2rem;
}

.journey-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.9rem;
}

.journey-card {
  background: rgba(255,255,255,0.88);
  border-radius: 18px;
  padding: 1rem;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
}

.journey-card h3 {
  font-size: 1rem;
  color: #12345a;
  margin-bottom: 0.45rem;
}

.journey-card p {
  font-size: 0.92rem;
  color: #36597d;
  margin: 0;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.8rem;
}

.skill-card {
  background: linear-gradient(135deg, #dbeafe, #eef6ff);
  border-radius: 18px;
  padding: 0.95rem;
  text-align: center;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.07);
}

.skill-card span {
  display: block;
  font-size: 1.35rem;
  margin-bottom: 0.3rem;
}

.skill-card h3 {
  font-size: 0.95rem;
  margin: 0;
  color: #12345a;
}

.footprint-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 0.8rem;
}

.eyebrow {
  font-size: 0.8rem;
  letter-spacing: 0.18em;
  color: #9aa9bd;
  margin-bottom: 0.4rem;
}

.footprint-header h2 {
  border: 0;
  margin: 0;
  padding: 0;
  font-size: 2rem;
}

.footprint-stats {
  display: flex;
  gap: 1.2rem;
}

.stat-box {
  text-align: right;
}

.stat-box strong {
  display: block;
  font-size: 2.1rem;
  color: #c4a96c;
}

.stat-box span {
  font-size: 0.85rem;
  color: #8a8f99;
}

.footprint-board {
  background: #f4eee4;
  border-radius: 22px;
  padding: 1.2rem;
  border: 1px solid rgba(196, 169, 108, 0.18);
}

.group-title {
  font-size: 0.88rem;
  letter-spacing: 0.16em;
  color: #9d947f;
  margin-bottom: 0.7rem;
}

.lived-grid {
  display: flex;
  gap: 0.9rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.country-card {
  background: white;
  border: 2px solid #c8ad6d;
  border-radius: 16px;
  padding: 0.8rem 1rem;
  min-width: 130px;
  text-align: center;
  box-shadow: 0 4px 10px rgba(120, 100, 60, 0.08);
}

.country-card div {
  font-size: 1.4rem;
  margin-bottom: 0.4rem;
}

.country-card h3 {
  font-size: 0.95rem;
  margin: 0 0 0.2rem 0;
  color: #3a2d20;
}

.country-card p {
  margin: 0;
  font-size: 0.82rem;
  color: #8a847b;
}

.explored-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
}

.country-chip {
  background: white;
  border: 1px solid #ead9cc;
  border-radius: 14px;
  padding: 0.7rem 0.95rem;
  font-size: 0.9rem;
  color: #4a4238;
}

.human-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.9rem;
}

.human-card {
  position: relative;
  display: block;
  border-radius: 22px;
  overflow: hidden;
  min-height: 260px;
  text-decoration: none !important;
  color: white !important;
}

.human-card.wide {
  grid-column: span 2;
}

.human-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 0;
}

.human-card .overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1rem;
  background: linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05));
}

.human-card h3 {
  margin: 0 0 0.2rem 0;
  color: white;
  font-size: 1.05rem;
}

.human-card p {
  margin: 0;
  color: rgba(255,255,255,0.92);
  font-size: 0.9rem;
}

.section-intro {
  color: #4a688b;
  margin-bottom: 0.8rem;
}

.photo-grid {
  display: grid;
  gap: 0.8rem;
}

.three-grid {
  grid-template-columns: repeat(3, 1fr);
}

.four-grid {
  grid-template-columns: repeat(4, 1fr);
}

.two-grid {
  grid-template-columns: repeat(2, 1fr);
}

.photo-grid img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
}

@media (max-width: 1000px) {
  .about-hero,
  .journey-grid,
  .skills-grid,
  .human-grid,
  .three-grid,
  .four-grid,
  .two-grid {
    grid-template-columns: 1fr;
  }

  .footprint-header {
    flex-direction: column;
  }

  .footprint-stats {
    justify-content: flex-start;
  }

  .human-card.wide {
    grid-column: span 1;
  }

  .about-hero-photo img {
    margin: 0 auto;
  }
}

/* Stable About page */
main.content img[src*="about-photo"] {
  max-width: 220px;
  border-radius: 18px;
  box-shadow: 0 8px 18px rgba(80, 120, 170, 0.12);
  margin-bottom: 1rem;
}

main.content h1 {
  color: #102a43;
}

main.content h2 {
  color: #12345a;
  margin-top: 1.5rem;
  border-bottom: 2px solid rgba(59, 130, 246, 0.18);
  padding-bottom: 0.2rem;
}

main.content h3 {
  color: #1d4ed8;
  margin-top: 1rem;
  margin-bottom: 0.35rem;
}

main.content p,
main.content li {
  color: #36597d;
  font-size: 0.98rem;
  line-height: 1.7;
}

main.content ul {
  padding-left: 1.2rem;
}

/* About page upgrade */
body.page-about main.content,
body:has(.about-inline-photo) main.content {
  max-width: 1180px;
}

/* About image on right side of text */
.about-inline-photo {
  float: right;
  width: 250px;
  max-width: 250px;
  margin: 0 0 1rem 1.4rem;
  border-radius: 20px;
  box-shadow: 0 10px 22px rgba(80, 120, 170, 0.12);
}

/* Clear float after intro area */
h2 {
  clear: both;
}

/* Core skills table */
table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  margin-top: 0.6rem;
  margin-bottom: 1.2rem;
  overflow: hidden;
  border-radius: 16px;
  box-shadow: 0 8px 18px rgba(80, 120, 170, 0.08);
}

thead th {
  background: #dbeafe;
  color: #12345a;
  padding: 0.85rem 0.9rem;
  text-align: left;
  font-weight: 700;
}

tbody td {
  background: rgba(255,255,255,0.88);
  color: #36597d;
  padding: 0.82rem 0.9rem;
  border-top: 1px solid rgba(59, 130, 246, 0.10);
}

/* Global footprint list */
h3 + ul {
  background: rgba(255,255,255,0.78);
  border-radius: 16px;
  padding: 0.9rem 1.2rem 0.9rem 2rem;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.07);
  margin-bottom: 1rem;
}

/* Human behind the CV images */
.gallery-photo {
  width: 220px;
  height: 220px;
  object-fit: cover;
  border-radius: 18px;
  margin: 0.35rem 0.45rem 0.45rem 0;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
  display: inline-block;
}

/* Section intros nicer */
main.content h1 {
  color: #102a43;
  font-size: 2.5rem;
}

main.content h2 {
  color: #12345a;
  margin-top: 1.6rem;
  border-bottom: 2px solid rgba(59, 130, 246, 0.18);
  padding-bottom: 0.2rem;
}

main.content h3 {
  color: #5a67d8;
  margin-top: 1rem;
  margin-bottom: 0.4rem;
}

main.content p,
main.content li {
  color: #36597d;
  line-height: 1.75;
}

@media (max-width: 900px) {
  .about-inline-photo {
    float: none;
    display: block;
    margin: 0 auto 1rem auto;
    width: 220px;
    max-width: 220px;
  }

  .gallery-photo {
    width: 100%;
    height: auto;
    display: block;
    margin-right: 0;
  }
}

/* Global footprint simple flags */
.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin: 0.4rem 0 1rem 0;
}

.flag-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 58px;
  height: 58px;
  font-size: 1.8rem;
  background: rgba(255,255,255,0.92);
  border-radius: 16px;
  box-shadow: 0 6px 14px rgba(80, 120, 170, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.08);
}

/* Behind the CV gallery */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(180px, 1fr));
  gap: 0.8rem;
  margin: 0.6rem 0 1.1rem 0;
}

.gallery-photo {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
  display: block;
}

/* Make section title cleaner */
h2 {
  clear: both;
}

@media (max-width: 900px) {
  .gallery-grid {
    grid-template-columns: 1fr;
  }

  .flag-pill {
    width: 52px;
    height: 52px;
    font-size: 1.6rem;
  }
}

/* about photo on right */
.about-inline-photo {
  float: right;
  width: 250px;
  max-width: 250px;
  margin: 0 0 1rem 1.4rem;
  border-radius: 20px;
  box-shadow: 0 10px 22px rgba(80, 120, 170, 0.12);
}

h2 {
  clear: both;
}

/* flags */
.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin: 0.4rem 0 1rem 0;
}

.flag-row p {
  margin: 0;
  display: flex;
  gap: 0.7rem;
  flex-wrap: wrap;
}

.flag-row p, .flag-row {
  font-size: 2rem;
}

/* behind the cv cards */
.behind-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(220px, 1fr));
  gap: 1rem;
  margin-top: 0.8rem;
}

.behind-card {
  background: rgba(255,255,255,0.9);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 10px 22px rgba(80, 120, 170, 0.10);
  padding-bottom: 0.8rem;
}

.behind-card p {
  margin: 0;
}

.behind-card a {
  text-decoration: none !important;
  color: inherit !important;
}

.behind-card-img {
  width: 100%;
  height: 250px;
  object-fit: cover;
  display: block;
  border-radius: 0;
  margin: 0 0 0.7rem 0;
  box-shadow: none;
}

.behind-card h3 {
  color: #4f46e5;
  font-size: 1.1rem;
  margin: 0 0 0.2rem 1rem;
}

.behind-card > p:last-child {
  color: #4a688b;
  font-size: 0.92rem;
  margin: 0 1rem;
  line-height: 1.55;
}

/* detail pages */
.detail-gallery {
  display: grid;
  grid-template-columns: repeat(3, minmax(220px, 1fr));
  gap: 0.9rem;
  margin-top: 1rem;
}

.detail-gallery img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
}

@media (max-width: 900px) {
  .about-inline-photo {
    float: none;
    display: block;
    margin: 0 auto 1rem auto;
    width: 220px;
    max-width: 220px;
  }

  .behind-grid,
  .detail-gallery {
    grid-template-columns: 1fr;
  }
}

.media-gallery {
  display: grid;
  grid-template-columns: repeat(3, minmax(180px, 1fr));
  gap: 0.9rem;
  margin-top: 1rem;
}

.media-thumb,
.video-thumb {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 18px;
  box-shadow: 0 8px 16px rgba(80, 120, 170, 0.08);
  cursor: pointer;
  background: #eef6ff;
}

.video-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #1d4ed8;
  font-size: 1rem;
}

.media-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10, 20, 35, 0.82);
  z-index: 9999;
  align-items: center;
  justify-content: center;
}

.media-modal-content {
  position: relative;
  width: min(90vw, 980px);
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.media-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-media {
  max-width: 100%;
  max-height: 78vh;
  border-radius: 18px;
  box-shadow: 0 10px 24px rgba(0,0,0,0.25);
}

.media-close {
  position: absolute;
  top: -8px;
  right: 0;
