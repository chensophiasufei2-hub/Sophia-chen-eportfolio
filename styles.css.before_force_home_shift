/* ===== Home side navigation: glass + active highlight ===== */
html {
  scroll-behavior: smooth;
}

.home-side-nav {
  position: fixed;
  right: 18px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 999;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  padding: 0.75rem;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow:
    0 12px 28px rgba(110, 120, 170, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.26);
  border: 1px solid rgba(255, 255, 255, 0.28);
}

.home-side-nav::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 24px;
  pointer-events: none;
  box-shadow: 0 0 0 1px rgba(196, 184, 239, 0.18), 0 0 24px rgba(170, 160, 230, 0.10);
}

.home-side-nav a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 98px;
  height: 38px;
  padding: 0 0.95rem;
  border-radius: 999px;
  text-decoration: none !important;
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: #666fd0 !important;
  background: rgba(255, 255, 255, 0.42);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(180, 185, 230, 0.22);
  box-shadow: 0 6px 14px rgba(120, 130, 190, 0.08);
  transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
}

.home-side-nav a:hover {
  transform: translateX(-3px);
  background: rgba(255, 255, 255, 0.64);
  color: #5f68cb !important;
  box-shadow: 0 10px 18px rgba(120, 130, 190, 0.14);
}

.home-side-nav a.is-active {
  background: linear-gradient(90deg, rgba(125, 134, 223, 0.92) 0%, rgba(163, 151, 233, 0.92) 100%);
  color: #ffffff !important;
  border-color: rgba(143, 152, 234, 0.55);
  box-shadow:
    0 10px 20px rgba(125, 134, 223, 0.22),
    0 0 18px rgba(143, 152, 234, 0.20);
}

@media (max-width: 1100px) {
  .home-side-nav {
    right: 10px;
    padding: 0.55rem;
  }

  .home-side-nav a {
    min-width: 84px;
    height: 36px;
    font-size: 0.82rem;
  }
}

@media (max-width: 820px) {
  .home-side-nav {
    display: none;
  }
}

