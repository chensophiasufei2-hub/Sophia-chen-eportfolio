  box-shadow: 0 0 14px rgba(255,255,255,.24), 0 0 30px rgba(234,221,255,.28), 0 18px 36px rgba(145,124,206,.18);
}

.landing-note {
  position: relative;
  z-index: 2;
  margin-top: 1.05rem;
  font-size: .96rem;
  color: rgba(255,255,255,.82);
  opacity: 0;
  animation: softFloatIn 1.6s ease forwards;
  animation-delay: 5.6s;
}

@keyframes type {
  from { width: 0; }
  to { width: 23ch; }
}

@keyframes caretBlink {
  0%, 49% { border-color: rgba(255,255,255,.92); }
  50%, 100% { border-color: transparent; }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes softFloatIn {
  0% { opacity: 0; transform: translateY(16px) scale(.985); }
  70% { opacity: .85; transform: translateY(2px) scale(1.005); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes pulseGlowSoft {
  0%, 100% {
    box-shadow: 0 0 10px rgba(255,255,255,.18), 0 0 26px rgba(226,212,255,.22), 0 16px 32px rgba(145,124,206,.14);
  }
  50% {
    box-shadow: 0 0 18px rgba(255,255,255,.26), 0 0 34px rgba(234,221,255,.28), 0 18px 38px rgba(145,124,206,.18);
  }
}

@keyframes cardFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes shimmerSlide {
  0% { transform: translateX(-120%); }
  45% { transform: translateX(120%); }
  100% { transform: translateX(120%); }
}

@keyframes driftGlow {
  0%, 100% { transform: translate(0,0) scale(1); opacity: .85; }
  50% { transform: translate(12px,-10px) scale(1.05); opacity: 1; }
}

@keyframes orbFloat1 {
  0%, 100% { transform: translateY(0) translateX(0); }
  50% { transform: translateY(-18px) translateX(12px); }
}

@keyframes orbFloat2 {
