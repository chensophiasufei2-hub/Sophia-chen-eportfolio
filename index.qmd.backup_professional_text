@keyframes sparkRise1 {
  0%   { transform: translateY(0) translateX(0) scale(.6); opacity: 0; }
  10%  { opacity: .9; }
  50%  { transform: translateY(-45vh) translateX(12px) scale(1); opacity: .85; }
  100% { transform: translateY(-95vh) translateX(-8px) scale(.7); opacity: 0; }
}

@keyframes sparkRise2 {
  0%   { transform: translateY(0) translateX(0) scale(.55); opacity: 0; }
  12%  { opacity: .75; }
